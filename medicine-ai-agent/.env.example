# =========================
# MongoDB 配置
# =========================
# 推荐直接填写完整连接串，支持账号、密码、认证库等参数
MONGODB_URI=mongodb://root:123456@localhost:27017
# 业务数据库名
MONGODB_DB_NAME=medicine
# 连接超时，单位毫秒
MONGODB_TIMEOUT_MS=3000
# 服务启动时是否执行 ping 校验，true/false
MONGODB_STARTUP_PING_ENABLED=false

# =========================
# Neo4j 图数据库配置
# =========================
# 连接地址，推荐使用 bolt 协议
NEO4J_URI=bolt://localhost:7687
# 连接账号
NEO4J_USER=neo4j
# 连接密码，请按本地环境填写
NEO4J_PASSWORD=123456
# 数据库名，默认 neo4j
NEO4J_DATABASE=medicicne
# 客户端超时，单位秒
NEO4J_TIMEOUT_SECONDS=3.0
# 服务启动时是否执行连通性校验，true/false
NEO4J_STARTUP_PING_ENABLED=false

# =========================
# Redis 配置
# =========================
# 如果填写 REDIS_URL，下面的 HOST/PORT/DB/PASSWORD/SSL 会被忽略
# 示例：redis://:password@localhost:6379/0
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=123456
# 是否启用 SSL，true/false
REDIS_SSL=false

# =========================
# RabbitMQ 配置
# =========================
# RabbitMQ 主机地址；只要设置该值，应用启动时就会启用 MQ
RABBITMQ_HOST=localhost
# RabbitMQ 端口
RABBITMQ_PORT=
# RabbitMQ 用户名
RABBITMQ_USERNAME=guest
# RabbitMQ 密码
RABBITMQ_PASSWORD=123456
# RabbitMQ 虚拟主机
RABBITMQ_VHOST=

# =========================
# 业务服务 HTTP 配置
# =========================
# 业务服务基础地址，需包含协议、主机和端口
# 示例：http://localhost:8083
HTTP_BASE_URL=http://localhost:8083
# 是否打印 HTTP 客户端请求/响应日志，true/false
HTTP_CLIENT_LOG_ENABLED=true

# =========================
# 业务服务系统鉴权配置
# =========================
# Agent 服务作为调用方时使用的 app_id；调用业务服务时会写入请求头 X-Agent-Key
X_AGENT_KEY=medicine-agent
# Agent 服务作为调用方时使用的签名密钥；需与业务服务 SYSTEM_AUTH_CLIENTS_JSON 中对应 secret 保持一致
SYSTEM_AUTH_LOCAL_SECRET=123456
# Agent 服务允许的系统客户端 JSON；当前主要用于 medicine-admin -> medicine-agent 的系统签名调用
SYSTEM_AUTH_CLIENTS_JSON=[{"app_id":"medicine-admin","secret":"123456","enabled":true}]
# 业务服务对齐参考：如需开启 medicine-agent -> medicine-admin 的系统签名调用，业务服务需放行 medicine-agent
# MEDICINE_ADMIN_SYSTEM_AUTH_CLIENTS_JSON=[{"app_id":"medicine-agent","secret":"123456","enabled":true}]
# Agent 服务对齐参考：以下命名仅用于跨项目说明，当前服务实际读取的仍是上面的 X_AGENT_KEY / SYSTEM_AUTH_LOCAL_SECRET / SYSTEM_AUTH_CLIENTS_JSON
# MEDICINE_AGENT_X_AGENT_KEY=medicine-agent
# MEDICINE_AGENT_SYSTEM_AUTH_LOCAL_SECRET=123456
# MEDICINE_AGENT_SYSTEM_AUTH_CLIENTS_JSON=[{"app_id":"medicine-admin","secret":"123456","enabled":true}]

# =========================
# Milvus 向量数据库配置
# =========================
# 优先使用 MILVUS_URI；为空时会自动按 HOST + PORT 拼接
# 示例：http://localhost:19530
MILVUS_URI=
MILVUS_HOST=localhost
MILVUS_PORT=19530
# 用户名，代码同时兼容 MILVUS_USERNAME，这里统一写 MILVUS_USER
MILVUS_USER=
MILVUS_PASSWORD=123456
# 如果你的 Milvus 使用 token 鉴权，可以直接填 token
MILVUS_TOKEN=
# 可选数据库名，不填则使用默认库
MILVUS_DB_NAME=medicine
# 客户端超时，单位秒；留空表示使用默认行为
MILVUS_TIMEOUT=


# 是否开启 LangSmith tracing，true/false；默认建议关闭，需要时再改成 true
LANGSMITH_TRACING=false
# LangSmith API Key；仅在开启 tracing 时填写
LANGSMITH_API_KEY=
# LangSmith 项目名；按需填写
LANGSMITH_PROJECT=medicine-ai-agent
# LangSmith 服务地址；官方云默认可使用该地址
LANGSMITH_ENDPOINT=
