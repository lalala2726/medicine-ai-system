{
  "name": "ant-design-pro",
  "version": "6.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "repository": "git@github.com:ant-design/ant-design-pro.git",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run build && npm run gh-pages",
    "dev": "vite",
    "gh-pages": "gh-pages -d dist",
    "jest": "jest",
    "lint": "eslint src/ --ext .ts,.tsx && npm run tsc",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,less,css}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "preview": "vite preview --port 8000",
    "start": "vite",
    "start:dev": "cross-env REACT_APP_ENV=dev vite",
    "start:pre": "cross-env REACT_APP_ENV=pre vite",
    "start:test": "cross-env REACT_APP_ENV=test vite",
    "start:no-mock": "cross-env REACT_APP_ENV=dev vite",
    "test": "jest",
    "test:coverage": "npm run jest -- --coverage",
    "test:update": "npm run jest -- -u",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "5.6.1",
    "@ant-design/plots": "^2.6.6",
    "@ant-design/pro-components": "2.7.19",
    "@ant-design/v5-patch-for-react-19": "1.0.3",
    "@ant-design/x": "^2.2.2",
    "@ant-design/x-markdown": "2.0.0",
    "@antv/gpt-vis": "^0.5.9",
    "@chatui/core": "^3.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@vitejs/plugin-react": "^5.1.4",
    "ahooks": "^3.9.6",
    "aieditor": "^1.4.1",
    "antd": "5.25.4",
    "antd-img-crop": "^4.25.0",
    "antd-style": "^3.7.0",
    "axios": "^1.13.5",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.13",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^0.554.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-json-view": "^1.21.3",
    "react-router-dom": "^7.13.1",
    "swagger-ui-dist": "^5.31.0",
    "vite": "^7.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.10",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^4.21.1",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^29.7.0",
    "less": "^4.5.1",
    "lint-staged": "^16.1.2",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
