<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhangyichuang.medicine.client.mapper.UserWalletMapper">

    <resultMap id="BaseResultMap" type="com.zhangyichuang.medicine.model.entity.UserWallet">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="walletNo" column="wallet_no"/>
        <result property="balance" column="balance"/>
        <result property="frozenBalance" column="frozen_balance"/>
        <result property="totalIncome" column="total_income"/>
        <result property="totalExpend" column="total_expend"/>
        <result property="currency" column="currency"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="freezeReason" column="freeze_reason"/>
        <result property="freezeTime" column="freeze_time"/>
        <result property="version" column="version"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,wallet_no,balance,frozen_balance,total_income,
        total_expend,currency,status,remark,freeze_reason,freeze_time,version,is_deleted,created_at,
        updated_at
    </sql>

    <!-- 按用户 ID 查询钱包并加写锁。 -->
    <select id="selectWalletByUserIdForUpdate" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user_wallet
        WHERE user_id = #{userId}
        AND (is_deleted IS NULL OR is_deleted = 0)
        LIMIT 1
        FOR UPDATE
    </select>

    <!-- 原子扣减钱包余额。 -->
    <update id="deductBalanceAtomic">
        UPDATE user_wallet
        SET balance      = balance - #{amount},
            total_expend = total_expend + #{amount},
            updated_at   = NOW()
        WHERE user_id = #{userId}
          AND balance >= #{amount}
          AND status = 0
          AND (is_deleted IS NULL OR is_deleted = 0)
    </update>

    <!-- 原子增加钱包余额。 -->
    <update id="addBalanceAtomic">
        UPDATE user_wallet
        SET balance      = balance + #{amount},
            total_income = total_income + #{amount},
            updated_at   = NOW()
        WHERE user_id = #{userId}
          AND status = 0
          AND (is_deleted IS NULL OR is_deleted = 0)
    </update>
</mapper>
