<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhangyichuang.medicine.admin.mapper.KbDocumentChunkMapper">

    <resultMap id="BaseResultMap" type="com.zhangyichuang.medicine.model.entity.KbDocumentChunk">
        <id property="id" column="id"/>
        <result property="documentId" column="document_id"/>
        <result property="knowledgeBaseId" column="knowledge_base_id"/>
        <result property="chunkIndex" column="chunk_index"/>
        <result property="content" column="content"/>
        <result property="vectorId" column="vector_id"/>
        <result property="charCount" column="char_count"/>
        <result property="status" column="status"/>
        <result property="stage" column="stage"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,document_id,knowledge_base_id,chunk_index,content,vector_id,char_count,
        status,stage,created_at,updated_at
    </sql>

    <select id="listDocumentChunk" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM kb_document_chunk
        <where>
            document_id = #{documentId}
        </where>
        ORDER BY chunk_index ASC, id ASC
    </select>

    <select id="selectMaxChunkIndex" resultType="java.lang.Integer">
        SELECT COALESCE(MAX(chunk_index), 0)
        FROM kb_document_chunk
        WHERE document_id = #{documentId}
    </select>
</mapper>
