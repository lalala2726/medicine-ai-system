<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhangyichuang.medicine.admin.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="com.zhangyichuang.medicine.model.entity.SysOperationLog">
        <id property="id" column="id"/>
        <result property="module" column="module"/>
        <result property="action" column="action"/>
        <result property="requestUri" column="request_uri"/>
        <result property="httpMethod" column="http_method"/>
        <result property="methodName" column="method_name"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="ip" column="ip"/>
        <result property="userAgent" column="user_agent"/>
        <result property="requestParams" column="request_params"/>
        <result property="responseResult" column="response_result"/>
        <result property="costTime" column="cost_time"/>
        <result property="success" column="success"/>
        <result property="errorMsg" column="error_msg"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,module,action,request_uri,http_method,method_name,
        user_id,username,ip,user_agent,
        request_params,response_result,cost_time,success,error_msg,
        create_time
    </sql>

    <select id="logList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_operation_log
        <where>
            <if test="query.module != null and query.module != ''">
                AND module LIKE CONCAT('%', #{query.module}, '%')
            </if>
            <if test="query.action != null and query.action != ''">
                AND action LIKE CONCAT('%', #{query.action}, '%')
            </if>
            <if test="query.username != null and query.username != ''">
                AND username LIKE CONCAT('%', #{query.username}, '%')
            </if>
            <if test="query.success != null">
                AND success = #{query.success}
            </if>
            <if test="query.startTime != null">
                AND create_time &gt;= #{query.startTime}
            </if>
            <if test="query.endTime != null">
                AND create_time &lt;= #{query.endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
</mapper>
