# Business backend reverse proxy target
API_PROXY_TARGET=http://localhost:8081

# AI backend reverse proxy target
AI_AGENT_PROXY_TARGET=http://localhost:8000

# LangSmith tracing switch
LANGSMITH_TRACING=false

# LangSmith API key, replace with your real key before use
LANGSMITH_API_KEY=

# LangSmith SaaS endpoint, replace if you use EU region or self-hosted LangSmith
LANGSMITH_ENDPOINT=

# LangSmith project name
LANGSMITH_PROJECT=medicine-client

# Optional: workspace id for keys bound to multiple workspaces
LANGSMITH_WORKSPACE_ID=
