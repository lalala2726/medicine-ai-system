<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhangyichuang.medicine.client.mapper.MallOrderMapper">

    <!-- 订单DTO结果映射 -->
    <resultMap id="MallOrderDtoMap" type="com.zhangyichuang.medicine.client.model.dto.MallOrderDto">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="itemsAmount" column="items_amount"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="payAmount" column="pay_amount"/>
        <result property="freightAmount" column="freight_amount"/>
        <result property="couponId" column="coupon_id"/>
        <result property="couponName" column="coupon_name"/>
        <result property="couponDeductAmount" column="coupon_deduct_amount"/>
        <result property="couponConsumeAmount" column="coupon_consume_amount"/>
        <result property="couponWasteAmount" column="coupon_waste_amount"/>
        <result property="payType" column="pay_type"/>
        <result property="orderStatus" column="order_status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="addressId" column="address_id"/>
        <result property="receiverName" column="receiver_name"/>
        <result property="receiverPhone" column="receiver_phone"/>
        <result property="receiverDetail" column="receiver_detail"/>
        <result property="note" column="note"/>
        <result property="payExpireTime" column="pay_expire_time"/>
        <result property="refundStatus" column="refund_status"/>
        <result property="refundTime" column="refund_time"/>
        <result property="refundPrice" column="refund_price"/>
        <result property="afterSaleFlag" column="after_sale_flag"/>
        <result property="payTime" column="pay_time"/>
        <result property="paid" column="paid"/>
        <result property="deliverTime" column="deliver_time"/>
        <result property="receiveTime" column="receive_time"/>
        <result property="finishTime" column="finish_time"/>
        <result property="closeReason" column="close_reason"/>
        <result property="closeTime" column="close_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="remark" column="remark"/>
        <result property="version" column="version"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <!-- 订单详情DTO结果映射 -->
    <resultMap id="OrderDetailDtoMap" type="com.zhangyichuang.medicine.client.model.dto.OrderDetailDto">
        <id property="id" column="id"/>
        <result property="orderNo" column="orderNo"/>
        <result property="orderStatus" column="orderStatus"/>
        <result property="itemsAmount" column="itemsAmount"/>
        <result property="totalAmount" column="totalAmount"/>
        <result property="payAmount" column="payAmount"/>
        <result property="freightAmount" column="freightAmount"/>
        <result property="couponId" column="couponId"/>
        <result property="couponName" column="couponName"/>
        <result property="couponDeductAmount" column="couponDeductAmount"/>
        <result property="couponConsumeAmount" column="couponConsumeAmount"/>
        <result property="payType" column="payType"/>
        <result property="deliveryType" column="deliveryType"/>
        <result property="paid" column="paid"/>
        <result property="payExpireTime" column="payExpireTime"/>
        <result property="payTime" column="payTime"/>
        <result property="deliverTime" column="deliverTime"/>
        <result property="receiveTime" column="receiveTime"/>
        <result property="finishTime" column="finishTime"/>
        <result property="createTime" column="createTime"/>
        <result property="note" column="note"/>
        <result property="afterSaleFlag" column="afterSaleFlag"/>
        <result property="refundStatus" column="refundStatus"/>
        <result property="refundPrice" column="refundPrice"/>
        <result property="refundTime" column="refundTime"/>
        <result property="receiverName" column="receiverName"/>
        <result property="receiverPhone" column="receiverPhone"/>
        <result property="receiverDetail" column="receiverDetail"/>
    </resultMap>

    <!-- 订单DTO字段列表 -->
    <sql id="MallOrderDto_Column_List">
        id, order_no, user_id, items_amount, total_amount, pay_amount, freight_amount,
        coupon_id, coupon_name, coupon_deduct_amount, coupon_consume_amount, coupon_waste_amount,
        pay_type, order_status, delivery_type, address_id, receiver_name,
        receiver_phone, receiver_detail, note, pay_expire_time, refund_status,
        refund_time, refund_price, after_sale_flag, pay_time, paid, deliver_time,
        receive_time, finish_time, close_reason, close_time, create_time,
        update_time, create_by, update_by, remark, version, is_deleted
    </sql>

    <!-- 订单列表查询 -->
    <select id="selectOrderList" resultMap="MallOrderDtoMap">
        SELECT
        <include refid="MallOrderDto_Column_List"/>
        FROM mall_order o
        WHERE (o.is_deleted = 0)
        AND o.user_id = #{userId}
        <if test="request.orderStatus != null and request.orderStatus != ''">
            AND o.order_status = #{request.orderStatus}
        </if>
        <if test="request.orderNo != null and request.orderNo != ''">
            AND o.order_no LIKE CONCAT('%', #{request.orderNo}, '%')
        </if>
        <if test="request.productName != null and request.productName != ''">
            AND EXISTS (
            SELECT 1 FROM mall_order_item oi
            WHERE (oi.is_deleted = 0)
            AND oi.order_id = o.id
            AND oi.product_name LIKE CONCAT('%', #{request.productName}, '%')
            )
        </if>
        ORDER BY o.create_time DESC
    </select>

    <!-- 订单详情查询 -->
    <select id="getOrderDetailByOrderNo" resultMap="OrderDetailDtoMap">
        SELECT o.id,
               o.order_no              AS orderNo,
               o.order_status          AS orderStatus,
               o.items_amount          AS itemsAmount,
               o.total_amount          AS totalAmount,
               o.pay_amount            AS payAmount,
               o.freight_amount        AS freightAmount,
               o.coupon_id             AS couponId,
               o.coupon_name           AS couponName,
               o.coupon_deduct_amount  AS couponDeductAmount,
               o.coupon_consume_amount AS couponConsumeAmount,
               o.pay_type              AS payType,
               o.delivery_type         AS deliveryType,
               o.paid,
               o.pay_expire_time       AS payExpireTime,
               o.pay_time              AS payTime,
               o.deliver_time          AS deliverTime,
               o.receive_time          AS receiveTime,
               o.finish_time           AS finishTime,
               o.create_time           AS createTime,
               o.note,
               o.after_sale_flag       AS afterSaleFlag,
               o.refund_status         AS refundStatus,
               o.refund_price          AS refundPrice,
               o.refund_time           AS refundTime,
               o.receiver_name         AS receiverName,
               o.receiver_phone        AS receiverPhone,
               o.receiver_detail       AS receiverDetail
        FROM mall_order o
        WHERE (o.is_deleted = 0)
          AND o.order_no = #{orderNo}
          AND o.user_id = #{userId}
    </select>

</mapper>
