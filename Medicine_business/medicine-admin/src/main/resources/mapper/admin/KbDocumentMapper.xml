<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhangyichuang.medicine.admin.mapper.KbDocumentMapper">

    <resultMap id="BaseResultMap" type="com.zhangyichuang.medicine.model.entity.KbDocument">
        <id property="id" column="id"/>
        <result property="knowledgeBaseId" column="knowledge_base_id"/>
        <result property="fileName" column="file_name"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileType" column="file_type"/>
        <result property="fileSize" column="file_size"/>
        <result property="chunkMode" column="chunk_mode"/>
        <result property="chunkSize" column="chunk_size"/>
        <result property="chunkOverlap" column="chunk_overlap"/>
        <result property="stage" column="stage"/>
        <result property="lastError" column="last_error"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="KnowledgeBaseDocumentResultMap"
               type="com.zhangyichuang.medicine.admin.model.dto.KnowledgeBaseDocumentDto"
               extends="BaseResultMap">
        <result property="chunkCount" column="chunk_count"/>
    </resultMap>

    <sql id="Base_Column_List">
        d.id,d.knowledge_base_id,d.file_name,d.file_url,
        d.file_type,d.file_size,d.chunk_mode,d.chunk_size,d.chunk_overlap,d.stage,d.last_error,d.create_by,
        d.update_by,d.created_at,d.updated_at
    </sql>

    <select id="listDocument" resultMap="KnowledgeBaseDocumentResultMap">
        SELECT
        <include refid="Base_Column_List"/>,
        COALESCE(chunk_detail.chunk_count, 0) AS chunk_count
        FROM kb_document d
        LEFT JOIN (
        SELECT
        document_id,
        COUNT(*) AS chunk_count
        FROM kb_document_chunk
        WHERE knowledge_base_id = #{knowledgeBaseId}
        AND document_id IS NOT NULL
        GROUP BY document_id
        ) chunk_detail ON chunk_detail.document_id = d.id
        <where>
            d.knowledge_base_id = #{knowledgeBaseId}
            <if test="request.fileName != null and request.fileName != ''">
                AND d.file_name LIKE CONCAT('%', TRIM(#{request.fileName}), '%')
            </if>
            <if test="request.fileType != null and request.fileType != ''">
                AND LOWER(d.file_type) = LOWER(REPLACE(TRIM(#{request.fileType}), '.', ''))
            </if>
        </where>
        ORDER BY d.created_at DESC, d.id DESC
    </select>

    <select id="getDocumentDetailById" resultMap="KnowledgeBaseDocumentResultMap">
        SELECT
        <include refid="Base_Column_List"/>,
        COALESCE(chunk_detail.chunk_count, 0) AS chunk_count
        FROM kb_document d
        LEFT JOIN (
        SELECT
        document_id,
        COUNT(*) AS chunk_count
        FROM kb_document_chunk
        WHERE document_id = #{id}
        GROUP BY document_id
        ) chunk_detail ON chunk_detail.document_id = d.id
        WHERE d.id = #{id}
    </select>
</mapper>
